# Copy this file to .env before running docker compose.
#
# Container networking defaults. Keep the ingest host at 0.0.0.0 when exposing
# the API through Docker port publishing.
SENDSPIN_INGEST_HOST=0.0.0.0
SENDSPIN_INGEST_PORT=8766
SENDSPIN_HOST=0.0.0.0
SENDSPIN_PORT=8927
SENDSPIN_ADVERTISE=false
SENDSPIN_MAX_BODY_MB=50
SENDSPIN_PLAYER_DIR=/opt/sendspin-service/player

# Cloud or internet-facing deployments should always set an API token.
# Producers must send it as: Authorization: Bearer <token>
SENDSPIN_API_TOKEN=change-this-token
